const express    = require('express');
const cors       = require('cors');
const http       = require('http');
const { Server } = require('socket.io');
const { Pool }   = require('pg');
require('dotenv').config();

const app    = express();
const server = http.createServer(app);         // wrap express in http server for socket.io
const io     = new Server(server, {
    cors: { origin: '*', methods: ['GET', 'POST'] }
});

app.use(cors());
app.use(express.json());

// ── Database ────────────────────────────────────────────────────────────────
const pool = new Pool({
    user:     process.env.DB_USER,
    password: process.env.DB_PASSWORD,
    host:     process.env.DB_HOST,
    port:     process.env.DB_PORT,
    database: process.env.DB_NAME,
});

pool.connect()
    .then(() => console.log('✅ Connected to PostgreSQL Database (LiveBridge DB)!'))
    .catch(err => console.error('❌ Database connection error:', err.stack));

// ── Socket.io ───────────────────────────────────────────────────────────────
// Track WebRTC rooms and hospital divert status in memory
const webrtcRooms         = {};
const hospitalDivertStatus = {};

io.on('connection', (socket) => {
    console.log(`🔌 Connected: ${socket.id}`);

    // Victim live location → dispatchers + hospital map
    socket.on('location_update', (data) => {
        io.emit('victim_location_update', data);
    });

    // Responder accepted dispatch
    socket.on('dispatch_accepted', ({ emergency_id, responder_id }) => {
        console.log(`🚑 ${responder_id} accepted SOS #${emergency_id}`);
        io.emit('dispatch_accepted', { emergency_id, responder_id });
    });

    // Responder GPS — also consumed by Ghost Driver script and Hospital map
    socket.on('responder_location', (data) => {
        io.emit('responder_location_update', data);
    });

    // Responder status update
    socket.on('responder_status_update', ({ emergency_id, status, responder_id }) => {
        console.log(`🚑 SOS #${emergency_id} [${responder_id || 'unit'}]: ${status}`);
        io.emit('responder_status_update', { emergency_id, status, responder_id });
    });

    // ── Hospital Events ──────────────────────────────────────────────────

    // Hospital joins their private room for targeted routing
    socket.on('hospital_join', ({ hospital_name }) => {
        socket.join(`hospital_${hospital_name}`);
        console.log(`🏥 Hospital "${hospital_name}" joined their room`);
        // Send current divert status so they sync on reconnect
        socket.emit('hospital_divert_update', {
            hospital_name,
            diverted: hospitalDivertStatus[hospital_name] || false,
        });
    });

    // Dispatcher routes an emergency to a specific hospital
    socket.on('route_to_hospital', ({ emergency_id, hospital_name, emergency_data }) => {
        io.to(`hospital_${hospital_name}`).emit('inbound_patient', {
            ...emergency_data,
            emergency_id,
            ambulance_unit: 'UP-14',
            routed_at: new Date().toISOString(),
        });
        console.log(`🏥 SOS #${emergency_id} → routed to ${hospital_name}`);
    });

    // Hospital confirms trauma team is ready
    socket.on('hospital_acknowledge', ({ emergency_id, hospital_name }) => {
        console.log(`✅ Hospital "${hospital_name}" acknowledged SOS #${emergency_id}`);
        // Push confirmation to all dispatchers — they show ✓ badge on their map
        io.emit('hospital_acknowledged', { emergency_id, hospital_name });
    });

    // Hospital toggles divert (ER full) — updates dispatcher map
    socket.on('hospital_divert', ({ hospital_name, diverted }) => {
        hospitalDivertStatus[hospital_name] = diverted;
        console.log(`🔄 Hospital "${hospital_name}" divert: ${diverted}`);
        io.emit('hospital_divert_update', { hospital_name, diverted });
    });

    // ── WebRTC Signalling ────────────────────────────────────────────────
    socket.on('webrtc_join', ({ room_id, role }) => {
        socket.join(room_id);
        if (!webrtcRooms[room_id]) webrtcRooms[room_id] = new Set();
        webrtcRooms[room_id].add(socket.id);
        console.log(`📹 ${role} joined WebRTC room ${room_id}`);
        socket.to(room_id).emit('webrtc_peer_joined', { role });
    });
    socket.on('webrtc_offer',         ({ room_id, sdp })       => socket.to(room_id).emit('webrtc_offer',         { sdp }));
    socket.on('webrtc_answer',        ({ room_id, sdp })       => socket.to(room_id).emit('webrtc_answer',        { sdp }));
    socket.on('webrtc_ice_candidate', ({ room_id, candidate }) => socket.to(room_id).emit('webrtc_ice_candidate', { candidate }));
    socket.on('webrtc_leave', ({ room_id }) => {
        socket.leave(room_id);
        if (webrtcRooms[room_id]) {
            webrtcRooms[room_id].delete(socket.id);
            if (webrtcRooms[room_id].size === 0) delete webrtcRooms[room_id];
        }
        socket.to(room_id).emit('webrtc_peer_left');
    });

    socket.on('disconnect', () => {
        // Clean up WebRTC rooms
        Object.entries(webrtcRooms).forEach(([room_id, sockets]) => {
            if (sockets.has(socket.id)) {
                sockets.delete(socket.id);
                socket.to(room_id).emit('webrtc_peer_left');
                if (sockets.size === 0) delete webrtcRooms[room_id];
            }
        });
        console.log(`🔌 Disconnected: ${socket.id}`);
    });
});

// ── Routes ──────────────────────────────────────────────────────────────────
app.get('/', (req, res) => res.send('🚑 LiveBridge Backend is ALIVE!'));

// ── Auth Routes (Login & Register) ──────────────────────────────────────────
const jwt = require('jsonwebtoken');
const bcrypt = require('bcryptjs');
const JWT_SECRET = process.env.JWT_SECRET || 'livebridge_dev_secret_change_in_prod';

function signToken(payload) {
  return jwt.sign(payload, JWT_SECRET, { expiresIn: '7d' });
}

// 1. REGISTER ROUTE
app.post('/api/auth/register', async (req, res) => {
  try {
    const { name, phone_number, password } = req.body;
    if (!name || !phone_number || !password) return res.status(400).json({ error: 'Missing fields.' });

    // Check if phone number already exists
    const exists = await pool.query('SELECT id FROM users WHERE phone_number = $1', [phone_number]);
    if (exists.rows.length > 0) return res.status(409).json({ error: 'Phone number already registered.' });

    // Hash password and save user
    const password_hash = await bcrypt.hash(password, 10);
    const result = await pool.query(
      `INSERT INTO users (name, phone_number, password_hash) VALUES ($1, $2, $3) RETURNING id, name, phone_number, created_at`,
      [name, phone_number, password_hash]
    );

    const user  = result.rows[0];
    const token = signToken({ id: user.id, name: user.name, phone: user.phone_number });
    
    // Return proper JSON response
    res.status(201).json({ message: 'Registered successfully!', token, user });
  } catch (err) {
    console.error("Registration Error:", err);
    res.status(500).json({ error: 'Registration failed.' });
  }
});

// 2. LOGIN ROUTE
app.post('/api/auth/login', async (req, res) => {
  try {
    const { phone_number, password } = req.body;
    if (!phone_number || !password) return res.status(400).json({ error: 'Missing fields.' });

    // Find user
    const result = await pool.query('SELECT * FROM users WHERE phone_number = $1', [phone_number]);
    if (result.rows.length === 0) return res.status(401).json({ error: 'Invalid credentials.' });

    const user  = result.rows[0];
    
    // Check password
    const valid = await bcrypt.compare(password, user.password_hash);
    if (!valid) return res.status(401).json({ error: 'Invalid credentials.' });

    const token = signToken({ id: user.id, name: user.name, phone: user.phone_number });
    
    // Return proper JSON response
    res.json({ message: 'Logged in!', token, user: { id: user.id, name: user.name, phone_number: user.phone_number } });
  } catch (err) {
    console.error("Login Error:", err);
    res.status(500).json({ error: 'Login failed.' });
  }
});

// ── In-memory OTP store (use Redis in production) ────────────────────────────
// { phone_number: { otp: '123456', expires: Date, attempts: 0 } }
const otpStore = {};
const OTP_TTL_MS  = 10 * 60 * 1000; // 10 minutes
const MAX_ATTEMPTS = 5;

function generateOTP() {
    return String(Math.floor(100000 + Math.random() * 900000)); // 6-digit
}

// POST /api/auth/forgot-password — request a password reset OTP
app.post('/api/auth/forgot-password', async (req, res) => {
    try {
        const { phone_number } = req.body;
        if (!phone_number) return res.status(400).json({ error: 'phone_number is required.' });

        // Check user exists
        const result = await pool.query(
            'SELECT id FROM users WHERE phone_number = $1', [phone_number]
        );
        // Always return 200 even if not found — prevents user enumeration
        if (result.rows.length === 0) {
            return res.json({ message: 'If that number is registered, an OTP has been sent.' });
        }

        const otp = generateOTP();
        otpStore[phone_number] = {
            otp,
            expires:  Date.now() + OTP_TTL_MS,
            attempts: 0,
        };

        // 🔴 PRODUCTION: Replace this console.log with real Twilio SMS
        // await twilioClient.messages.create({ body: `Your LiveBridge OTP is ${otp}`, to: phone_number, from: process.env.TWILIO_PHONE_NUMBER });
        console.log(`\n📲 PASSWORD RESET OTP for ${phone_number}: \x1b[33m${otp}\x1b[0m  (expires in 10 min)\n`);

        res.json({ message: 'OTP sent! Check your registered phone. (Demo: see server terminal)' });
    } catch (err) {
        console.error(err.message);
        res.status(500).json({ error: 'Failed to send OTP.' });
    }
});

// POST /api/auth/reset-password — verify OTP and set new password
app.post('/api/auth/reset-password', async (req, res) => {
    try {
        const { phone_number, otp, new_password } = req.body;
        if (!phone_number || !otp || !new_password) {
            return res.status(400).json({ error: 'phone_number, otp and new_password are required.' });
        }
        if (new_password.length < 6) {
            return res.status(400).json({ error: 'Password must be at least 6 characters.' });
        }

        const record = otpStore[phone_number];

        // Validate OTP exists
        if (!record) {
            return res.status(400).json({ error: 'No OTP was requested for this number. Please start again.' });
        }
        // Check expiry
        if (Date.now() > record.expires) {
            delete otpStore[phone_number];
            return res.status(400).json({ error: 'OTP has expired. Please request a new one.' });
        }
        // Track attempts
        record.attempts += 1;
        if (record.attempts > MAX_ATTEMPTS) {
            delete otpStore[phone_number];
            return res.status(429).json({ error: 'Too many failed attempts. Request a new OTP.' });
        }
        // Verify OTP
        if (record.otp !== otp.trim()) {
            return res.status(400).json({ error: `Incorrect OTP. ${MAX_ATTEMPTS - record.attempts} attempts remaining.` });
        }

        // OTP valid — update password
        const bcrypt = require('bcryptjs');
        const password_hash = await bcrypt.hash(new_password, 10);
        const updated = await pool.query(
            'UPDATE users SET password_hash = $1 WHERE phone_number = $2 RETURNING id',
            [password_hash, phone_number]
        );
        if (updated.rows.length === 0) {
            return res.status(404).json({ error: 'User not found.' });
        }

        // Clean up used OTP
        delete otpStore[phone_number];
        console.log(`✅ Password reset successful for ${phone_number}`);
        res.json({ message: 'Password updated successfully! Please sign in.' });

    } catch (err) {
        console.error(err.message);
        res.status(500).json({ error: 'Failed to reset password.' });
    }
});

